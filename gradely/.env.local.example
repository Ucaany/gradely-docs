# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (used for auth redirects — set to your production URL in prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI Integration (required for target analysis & WhatsApp message generation)
AI_API_KEY=your-ai-api-key
AI_BASE_URL=https://your-ai-provider.com/v1
AI_MODEL=your-model-name

# WAHA WhatsApp API (required for WhatsApp notifications)
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=your-waha-api-key
WAHA_SESSION=default

# Default password for bulk CSV import (min 8 chars, use strong password)
DEFAULT_IMPORT_PASSWORD=ChangeMe@2024
