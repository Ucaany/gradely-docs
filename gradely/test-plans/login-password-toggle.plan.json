{
  "projectId": "026062f0-daf8-4331-8a4e-509ad34a22b0",
  "type": "frontend",
  "name": "Login password show/hide toggle",
  "planSteps": [
    {
      "type": "action",
      "description": "Navigate to login page",
      "action": "navigate",
      "url": "https://graph-headstand-copper.ngrok-free.dev/login"
    },
    {
      "type": "action",
      "description": "Fill password field",
      "action": "fill",
      "selector": "#login-password",
      "value": "mypassword123"
    },
    {
      "type": "assertion",
      "description": "Password field should be masked by default",
      "selector": "#login-password",
      "assertion": "attribute",
      "attribute": "type",
      "value": "password"
    },
    {
      "type": "action",
      "description": "Click show/hide password toggle button",
      "action": "click",
      "selector": "button[tabindex='-1']"
    },
    {
      "type": "assertion",
      "description": "Password field should be visible after toggle",
      "selector": "#login-password",
      "assertion": "attribute",
      "attribute": "type",
      "value": "text"
    }
  ]
}
