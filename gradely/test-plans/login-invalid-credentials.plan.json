{
  "projectId": "026062f0-daf8-4331-8a4e-509ad34a22b0",
  "type": "frontend",
  "name": "Login invalid credentials shows error",
  "planSteps": [
    {
      "type": "action",
      "description": "Navigate to login page",
      "action": "navigate",
      "url": "https://graph-headstand-copper.ngrok-free.dev/login"
    },
    {
      "type": "action",
      "description": "Fill email with invalid credentials",
      "action": "fill",
      "selector": "#login-email",
      "value": "invalid@example.com"
    },
    {
      "type": "action",
      "description": "Fill password with wrong value",
      "action": "fill",
      "selector": "#login-password",
      "value": "wrongpassword123"
    },
    {
      "type": "action",
      "description": "Click submit button",
      "action": "click",
      "selector": "button[type='submit']"
    },
    {
      "type": "assertion",
      "description": "Error toast should appear for invalid credentials",
      "selector": "[data-sonner-toast]",
      "assertion": "visible"
    }
  ]
}
